# Copy to .env and fill in.

# PostgreSQL connection string.
# • Neon (production):  postgres://USER:PASSWORD@HOST/DB?sslmode=require
# • Local Docker:       postgres://chief:chief@localhost:5432/chief_report
DATABASE_URL=postgres://chief:chief@localhost:5432/chief_report

# API port (Render sets this automatically in production)
PORT=3001
